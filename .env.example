# Database
DATABASE_URL="postgresql://postgres@localhost:5432/shopy?schema=public"
DIRECT_URL=""
PRISMA_CLIENT_ENGINE_TYPE="binary"
PRISMA_CLI_QUERY_ENGINE_TYPE="binary"

# Runtime
NODE_ENV="development"
PORT=4000
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
PLATFORM_DEFAULT_CURRENCY="USD"

# Auth.js
AUTH_SECRET="shopy-dev-secret-change-in-production-32chars"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# API/Web
API_URL="http://localhost:4000"
API_INTERNAL_SECRET="shopy-internal-secret"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# Local smoke script
SMOKE_EMAIL="demo@Shopy.app"
SMOKE_PASSWORD="Demo12345!"

# Optional future integrations. Disabled by default for zero-spend MVP.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_WEBHOOK_SECRET=""
SHOPIFY_SCOPES=""
SHOPIFY_APP_URL=""
OPENAI_API_KEY=""
AI_PROVIDER="local"
EMAIL_PROVIDER="disabled"
SMS_PROVIDER="disabled"
META_APP_ID=""
META_APP_SECRET=""
MESCOLIS_API_KEY=""
MESCOLIS_API_URL=""
RESEND_API_KEY=""
EMAIL_FROM=""
