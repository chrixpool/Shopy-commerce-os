# Database
DATABASE_URL="postgresql://postgres@localhost:5432/shopy?schema=public"
DIRECT_URL=""
PRISMA_CLIENT_ENGINE_TYPE="binary"
PRISMA_CLI_QUERY_ENGINE_TYPE="binary"

# Runtime
NODE_ENV="development"
PORT=4000
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
PLATFORM_DEFAULT_CURRENCY="USD"
ENABLE_MANUAL_ORDER_WORKFLOWS=false

# Auth.js
AUTH_SECRET="shopy-dev-secret-change-in-production-32chars"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# API/Web
API_URL="http://localhost:4000"
API_INTERNAL_SECRET="shopy-internal-secret"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# Local smoke script
SMOKE_EMAIL="Oussemawarteni@shopy.com"
SMOKE_PASSWORD=""
SEED_OWNER_EMAIL="Oussemawarteni@shopy.com"
SEED_OWNER_PASSWORD=""
SEED_DEMO_DATA=false

# Production data cleanup. Dry-run by default; execute only after backup is confirmed.
DATA_CLEANUP_ORG="shopy-demo"
DELETE_SOURCES="SEED,DEMO,TEST"
CONFIRM_DATA_CLEANUP=""
BACKUP_CONFIRMED=false

# Optional integrations. Disabled by default for zero-spend MVP.
INTEGRATION_SECRET_KEY=""
MES_COLIS_ACCESS_TOKEN=""
MES_COLIS_API_URL="https://api.mescolis.tn/api"
MES_COLIS_SOCKET_URL="https://api.mescolis.tn:4001"
SHOPIFY_CONNECTION_METHOD="CLIENT_CREDENTIALS"
SHOPIFY_SHOP_DOMAIN=""
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
SHOPIFY_ADMIN_ACCESS_TOKEN=""
SHOPIFY_WEBHOOK_SECRET=""
SHOPIFY_API_VERSION="2026-01"
SHOPIFY_ALLOWED_SCOPES="read_orders,read_products,read_customers,read_inventory,read_locations,read_all_orders"
SHOPIFY_MAX_SYNC_PAGES=20
SHOPIFY_SCOPES=""
SHOPIFY_APP_URL=""
OPENAI_API_KEY=""
AI_PROVIDER="local"
EMAIL_PROVIDER="disabled"
SMS_PROVIDER="disabled"
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""
META_API_VERSION="v23.0"
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
INSTAGRAM_ACCESS_TOKEN=""
AUTOMATION_DRY_RUN_DEFAULT=true
MESCOLIS_API_KEY=""
MESCOLIS_API_URL=""
RESEND_API_KEY=""
EMAIL_FROM=""
