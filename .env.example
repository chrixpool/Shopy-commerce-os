SHOPIFY_ALLOWED_SCOPES="read_orders,read_products,read_customers,read_inventory,read_locations"
SHOPIFY_DEFAULT_SYNC_DAYS=30
SHOPIFY_SCOPES=""
SHOPIFY_APP_URL=""
OPENAI_API_KEY=""
AI_PROVIDER="local"
EMAIL_PROVIDER="disabled"
SMS_PROVIDER="disabled"
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
