{
  "name": "@shopy/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:migrate": "node ../../scripts/prisma-binary.mjs migrate dev",
